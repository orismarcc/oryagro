# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA commite o .env.local — ele está no .gitignore.

# Supabase — obtenha em: https://supabase.com/dashboard/project/<ref>/settings/api
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Supabase Personal Access Token — obtenha em: https://supabase.com/dashboard/account/tokens
# Usado apenas por scripts locais de migração, NUNCA exposto no frontend.
SUPABASE_ACCESS_TOKEN=<your-personal-access-token>
